From f1ca5c7d43e0b851233dcee17fac17b5b0cdb998 Mon Sep 17 00:00:00 2001
From: Dmitrii Sharshakov <d3dx12.xx@gmail.com>
Date: Tue, 17 Feb 2026 12:56:47 +0100
Subject: [PATCH] fix: make stage3 cross-compile for linux/arm64 again

Fixes: 52db83a839070f3b4857d87e62697f53bc9057d7 (feat: convert entire tree to be llvm native)
---
 packages/bootstrap/stage3/Containerfile | 14 ++++++++------
 1 file changed, 8 insertions(+), 6 deletions(-)

diff --git a/packages/bootstrap/stage3/Containerfile b/packages/bootstrap/stage3/Containerfile
index 4157bbbd..196b03ae 100644
--- a/packages/bootstrap/stage3/Containerfile
+++ b/packages/bootstrap/stage3/Containerfile
@@ -64,11 +64,12 @@ RUN --network=none <<-EOF
 	make CROSS_COMPILE=${TARGET}- defconfig
 	echo "CONFIG_STATIC=y" >> .config
 	make CROSS_COMPILE=${TARGET}-
-	mkdir -p /rootfs/usr/bin
-	cp busybox /rootfs/usr/bin
-	cp busybox /usr/bin
-	cd /rootfs
-	/usr/bin/busybox --install -s usr/bin
+	make CROSS_COMPILE=${TARGET}- busybox.links
+	# Create symlinks without actually invoking busybox - this is essential for cross-compilation
+	cat busybox.links | while read link; do
+	  ln -sf busybox "/rootfs/usr/bin/$(basename "$link")"
+	done
+	cp busybox /rootfs/usr/bin/
 	rm -rf /busybox-*
 EOF
 
@@ -371,9 +372,10 @@ RUN --network=none <<-EOF
 	rm -rf /libffi-*
 EOF
 
-FROM base AS libunwind
+FROM scratch AS libunwind
 ARG TARGETARCH
 ARG LIBUNWIND_VERSION
+COPY --from=base /rootfs/ /
 COPY --from=musl /rootfs/ /
 COPY --from=busybox /rootfs/ /
 COPY --from=make /rootfs/ /
-- 
2.52.0

